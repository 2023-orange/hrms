<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunten.hrms.pm.dao.PmEmployeePhotoDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.sunten.hrms.pm.domain.PmEmployeePhoto">
        <id column="id" property="id" />
        <result column="real_name" property="realName" />
        <result column="path" property="path" />
        <result column="avater_size" property="avaterSize" />
        <result column="update_by" property="updateBy" />
        <result column="create_by" property="createBy" />
        <result column="update_time" property="updateTime" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <resultMap id="PmEmployeePhotoResultMap" type="com.sunten.hrms.pm.domain.PmEmployeePhoto" autoMapping="true">
        <id column="id" property="id" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        <![CDATA[
            pep.real_name, pep.path, pep.avater_size, pep.id, pep.update_by, pep.create_by, pep.update_time, 
            pep.create_time 
        ]]>
    </sql>

    <!-- 带参数通用查询结果列 -->
    <sql id="Base_Column_With_Param_List">
        <![CDATA[
            ${tAlias}.real_name as ${tAlias}_real_name, ${tAlias}.path as ${tAlias}_path, 
            ${tAlias}.avater_size as ${tAlias}_avater_size, ${tAlias}.id as ${tAlias}_id, 
            ${tAlias}.update_by as ${tAlias}_update_by, ${tAlias}.create_by as ${tAlias}_create_by, 
            ${tAlias}.update_time as ${tAlias}_update_time, ${tAlias}.create_time as ${tAlias}_create_time 
        ]]>
    </sql>

    <sql id="Base_Column_Query_Sql">
        <![CDATA[
            select
        ]]>
        <include refid="Base_Column_List"/>
        <![CDATA[
              from pm_employee_photo pep
        ]]>
    </sql>

    <sql id="Select_All_Criteria_Sql">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
<!--        <if test="criteria != null">-->
<!--        <if test="criteria.xxxx != null">-->
<!--            <![CDATA[-->
<!--                and pep.xxxxx like #{criteria.xxxx,jdbcType=xxxx}-->
<!--            ]]>-->
<!--        </if>-->
<!--        </if>-->
    </sql>

    <insert id="insertAllColumn" parameterType="com.sunten.hrms.pm.domain.PmEmployeePhoto" useGeneratedKeys="true" keyProperty="id">
        <![CDATA[
            insert into pm_employee_photo (real_name, path, avater_size,
                                           update_by, create_by, update_time,
                                           create_time)
            values (#{realName,jdbcType=VARCHAR}, #{path,jdbcType=VARCHAR}, #{avaterSize,jdbcType=VARCHAR},
                    #{updateBy,jdbcType=BIGINT}, #{createBy,jdbcType=BIGINT}, #{updateTime,jdbcType=TIMESTAMP},
                    #{createTime,jdbcType=TIMESTAMP})
        ]]>
    </insert>

    <sql id="Delete_Sql">
        <![CDATA[
            delete
              from pm_employee_photo
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </sql>

    <delete id="deleteByKey">
        <include refid="Delete_Sql"/>
    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.pm.domain.PmEmployeePhoto">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.pm.domain.PmEmployeePhoto">
        <![CDATA[
            update pm_employee_photo
               set real_name   = #{realName,jdbcType=VARCHAR},
                   path        = #{path,jdbcType=VARCHAR},
                   avater_size = #{avaterSize,jdbcType=VARCHAR},
                   update_by   = #{updateBy,jdbcType=BIGINT},
                   update_time = #{updateTime,jdbcType=TIMESTAMP}
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="PmEmployeePhotoResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where pep.id = #{id,jdbcType=BIGINT}
        ]]>
    </select>

    <select id="listAllByCriteria" resultMap="PmEmployeePhotoResultMap">
        <include refid="Select_All_Criteria_Sql"/>
        <![CDATA[
            order by id
        ]]>
    </select>

    <select id="listAllByCriteriaPage" resultMap="PmEmployeePhotoResultMap">
        <include refid="Select_All_Criteria_Sql"/>
    </select>

</mapper>
