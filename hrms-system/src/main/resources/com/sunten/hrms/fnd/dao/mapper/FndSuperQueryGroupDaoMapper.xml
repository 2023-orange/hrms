<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunten.hrms.fnd.dao.FndSuperQueryGroupDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.sunten.hrms.fnd.domain.FndSuperQueryGroup">
        <id column="id" property="id" />
        <result column="group_name" property="groupName" />
        <result column="remark" property="remark" />
        <result column="enabled_flag" property="enabledFlag" />
        <result column="create_time" property="createTime" />
        <result column="create_by" property="createBy" />
        <result column="update_time" property="updateTime" />
        <result column="update_by" property="updateBy" />
    </resultMap>

    <resultMap id="FndSuperQueryGroupResultMap" type="com.sunten.hrms.fnd.domain.FndSuperQueryGroup" autoMapping="true">
        <id column="id" property="id" />
        <collection property="tables"
                    resultMap="com.sunten.hrms.fnd.dao.FndSuperQueryTableDao.FndSuperQueryTableResultMap"
                    columnPrefix="fsqt_"
        />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        <![CDATA[
            fsqg.id, fsqg.group_name, fsqg.remark, fsqg.enabled_flag, fsqg.create_time, fsqg.create_by,
            fsqg.update_time, fsqg.update_by
        ]]>
    </sql>

    <!-- 带参数通用查询结果列 -->
    <sql id="Base_Column_With_Param_List">
        <![CDATA[
            ${tAlias}.id as ${tAlias}_id, ${tAlias}.group_name as ${tAlias}_group_name,
            ${tAlias}.remark as ${tAlias}_remark, ${tAlias}.enabled_flag as ${tAlias}_enabled_flag,
            ${tAlias}.create_time as ${tAlias}_create_time, ${tAlias}.create_by as ${tAlias}_create_by,
            ${tAlias}.update_time as ${tAlias}_update_time, ${tAlias}.update_by as ${tAlias}_update_by
        ]]>
    </sql>

    <sql id="Base_Column_Query_Sql">
        <![CDATA[
            select
        ]]>
        <include refid="Base_Column_List"/>
        <![CDATA[
              from fnd_super_query_group fsqg
        ]]>
    </sql>

    <sql id="With_Out_Join_Query_Sql">
        <![CDATA[
		    select
		]]>
        <include refid="Base_Column_List"/>
        <![CDATA[,]]>
        <bind name="tAlias" value="'fsqt'"/>
        <include refid="com.sunten.hrms.fnd.dao.FndSuperQueryTableDao.Base_Column_With_Param_List"/>
        <![CDATA[,]]>
        <bind name="tAlias" value="'fsqt_fsqtc'"/>
        <include refid="com.sunten.hrms.fnd.dao.FndSuperQueryTableColumnDao.Base_Column_With_Param_List"/>
        <![CDATA[
			  from fnd_super_query_group fsqg
			  left outer join fnd_super_query_table fsqt
			    on fsqt.group_id = fsqg.id
			   and fsqt.enabled_flag = 1
			  left outer join fnd_super_query_table_column fsqt_fsqtc
			    on fsqt_fsqtc.group_id = fsqt.group_id
			   and fsqt_fsqtc.table_id = fsqt.id
			   and fsqt_fsqtc.enabled_flag = 1
		]]>
    </sql>

    <sql id="Criteria_Sql">
        <if test="criteria != null">
            <if test="criteria.groupName != null">
                <![CDATA[
                    and fsqg.group_name like #{criteria.groupName,jdbcType=VARCHAR}
                ]]>
            </if>
            <if test="criteria.enabledFlag != null">
                <![CDATA[
                    and fsqg.enabled_flag like #{criteria.enabledFlag,jdbcType=BIT}
                ]]>
            </if>
        </if>
    </sql>

    <sql id="Select_All_Criteria_Sql">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
        <include refid="Criteria_Sql"/>
    </sql>

    <insert id="insertAllColumn" parameterType="com.sunten.hrms.fnd.domain.FndSuperQueryGroup" useGeneratedKeys="true" keyProperty="id">
        <![CDATA[
            insert into fnd_super_query_group (group_name, remark, enabled_flag,
                                               create_time, create_by,
                                               update_time, update_by)
            values (#{groupName,jdbcType=VARCHAR}, #{remark,jdbcType=VARCHAR}, #{enabledFlag,jdbcType=BIT},
                    #{createTime,jdbcType=TIMESTAMP}, #{createBy,jdbcType=BIGINT},
                    #{updateTime,jdbcType=TIMESTAMP}, #{updateBy,jdbcType=BIGINT})
        ]]>
    </insert>

    <sql id="Delete_Sql">
        <![CDATA[
            delete
              from fnd_super_query_group
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </sql>

    <delete id="deleteByKey">
        <include refid="Delete_Sql"/>
    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.fnd.domain.FndSuperQueryGroup">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.fnd.domain.FndSuperQueryGroup">
        <![CDATA[
            update fnd_super_query_group
               set group_name   = #{groupName,jdbcType=VARCHAR},
                   remark       = #{remark,jdbcType=VARCHAR},
                   enabled_flag = #{enabledFlag,jdbcType=BIT},
                   update_time  = #{updateTime,jdbcType=TIMESTAMP},
                   update_by    = #{updateBy,jdbcType=BIGINT}
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="FndSuperQueryGroupResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where fsqg.id = #{id,jdbcType=BIGINT}
        ]]>
    </select>

    <select id="listAllByCriteriaExpand" resultMap="FndSuperQueryGroupResultMap">
        <include refid="With_Out_Join_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
        <include refid="Criteria_Sql"/>
        <![CDATA[
            order by id
        ]]>
    </select>

    <select id="listAllByCriteria" resultMap="FndSuperQueryGroupResultMap">
        <include refid="Select_All_Criteria_Sql"/>
        <![CDATA[
            order by id
        ]]>
    </select>

    <select id="listAllByCriteriaPage" resultMap="FndSuperQueryGroupResultMap">
        <include refid="Select_All_Criteria_Sql"/>
    </select>

</mapper>
