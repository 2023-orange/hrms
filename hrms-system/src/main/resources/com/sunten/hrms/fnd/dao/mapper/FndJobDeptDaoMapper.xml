    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.fnd.domain.FndJobDept">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.fnd.domain.FndJobDept">
        <![CDATA[
            update fnd_job_dept
               set update_time = #{updateTime,jdbcType=TIMESTAMP},
                   update_by   = #{updateBy,jdbcType=BIGINT}
             where dept_id = #{deptId,jdbcType=BIGINT}
               and job_id = #{jobId,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="FndJobDeptResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where fjd.dept_id = #{deptId,jdbcType=BIGINT}
               and fjd.job_id = #{jobId,jdbcType=BIGINT}
