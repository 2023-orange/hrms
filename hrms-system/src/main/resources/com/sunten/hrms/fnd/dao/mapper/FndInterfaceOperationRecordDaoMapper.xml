<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunten.hrms.fnd.dao.FndInterfaceOperationRecordDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.sunten.hrms.fnd.domain.FndInterfaceOperationRecord">
        <id column="id" property="id" />
        <result column="operation_value" property="operationValue" />
        <result column="success_flag" property="successFlag" />
        <result column="data_processing_description" property="dataProcessingDescription" />
        <result column="operation_description" property="operationDescription" />
        <result column="create_time" property="createTime" />
        <result column="create_by" property="createBy" />
        <result column="update_time" property="updateTime" />
        <result column="update_by" property="updateBy" />
    </resultMap>

    <resultMap id="FndInterfaceOperationRecordResultMap" type="com.sunten.hrms.fnd.domain.FndInterfaceOperationRecord" autoMapping="true">
        <id column="id" property="id" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        <![CDATA[
            fior.id, fior.operation_value, fior.success_flag, fior.data_processing_description,
            fior.operation_description, fior.create_time, fior.create_by, fior.update_time, fior.update_by
        ]]>
    </sql>

    <!-- 带参数通用查询结果列 -->
    <sql id="Base_Column_With_Param_List">
        <![CDATA[
            ${tAlias}.id as ${tAlias}_id,
            ${tAlias}.operation_value as ${tAlias}_operation_value,
            ${tAlias}.success_flag as ${tAlias}_success_flag,
            ${tAlias}.data_processing_description as ${tAlias}_data_processing_description,
            ${tAlias}.operation_description as ${tAlias}_operation_description,
            ${tAlias}.create_time as ${tAlias}_create_time, ${tAlias}.create_by as ${tAlias}_create_by,
            ${tAlias}.update_time as ${tAlias}_update_time, ${tAlias}.update_by as ${tAlias}_update_by
        ]]>
    </sql>

    <sql id="Base_Column_Query_Sql">
        <![CDATA[
            select
        ]]>
        <include refid="Base_Column_List"/>
        <![CDATA[
              from fnd_interface_operation_record fior
        ]]>
    </sql>

    <sql id="Select_All_Criteria_Sql">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
        <if test="criteria != null">
            <if test="criteria.operationValue != null">
                <![CDATA[
                    and fior.operation_value = #{criteria.operationValue,jdbcType=VARCHAR}
                ]]>
            </if>
        </if>
    </sql>

    <insert id="insertAllColumn" parameterType="com.sunten.hrms.fnd.domain.FndInterfaceOperationRecord" useGeneratedKeys="true" keyProperty="id">
        <![CDATA[
            insert into fnd_interface_operation_record (operation_value, success_flag,
                                                        data_processing_description, operation_description,
                                                        create_time, create_by,
                                                        update_time, update_by)
            values  ( #{operationValue,jdbcType=VARCHAR}, #{successFlag,jdbcType=BIT},
                    #{dataProcessingDescription,jdbcType=VARCHAR}, #{operationDescription,jdbcType=VARCHAR},
                    #{createTime,jdbcType=TIMESTAMP}, #{createBy,jdbcType=BIGINT},
                    #{updateTime,jdbcType=TIMESTAMP}, #{updateBy,jdbcType=BIGINT})
        ]]>
    </insert>

    <sql id="Delete_Sql">
        <![CDATA[
            delete
              from fnd_interface_operation_record
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </sql>

    <delete id="deleteByKey">
        <include refid="Delete_Sql"/>
    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.fnd.domain.FndInterfaceOperationRecord">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.fnd.domain.FndInterfaceOperationRecord">
        <![CDATA[
            update fnd_interface_operation_record
               set
                   operation_value             = #{operationValue,jdbcType=VARCHAR},
                   success_flag                = #{successFlag,jdbcType=BIT},
                   data_processing_description = #{dataProcessingDescription,jdbcType=VARCHAR},
                   operation_description       = #{operationDescription,jdbcType=VARCHAR},
                   update_time                 = #{updateTime,jdbcType=TIMESTAMP},
                   update_by                   = #{updateBy,jdbcType=BIGINT}
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="FndInterfaceOperationRecordResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where fior.id = #{id,jdbcType=BIGINT}
        ]]>
    </select>

    <select id="listAllByCriteria" resultMap="FndInterfaceOperationRecordResultMap">
        <include refid="Select_All_Criteria_Sql"/>
        <![CDATA[
            order by id desc
        ]]>
    </select>

    <select id="listAllByCriteriaPage" resultMap="FndInterfaceOperationRecordResultMap">
        <include refid="Select_All_Criteria_Sql"/>
    </select>

</mapper>
