<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunten.hrms.re.dao.ReDemandTrackingDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.sunten.hrms.re.domain.ReDemandTracking">
        <id column="id" property="id" />
        <result column="demand_id" property="demandId" />
        <result column="re_content" property="reContent" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="create_by" property="createBy" />
        <result column="enabled_flag" property="enabledFlag"/>
        <result column="edit_by" property="editBy"/>
    </resultMap>

    <resultMap id="ReDemandTrackingResultMap" type="com.sunten.hrms.re.domain.ReDemandTracking" autoMapping="true">
        <id column="id" property="id" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        <![CDATA[
            rdt.demand_id, rdt.re_content, rdt.id, rdt.create_time, rdt.update_by, rdt.update_time,
            rdt.create_by,rdt.enabled_flag, rdt.edit_by
        ]]>
    </sql>

    <!-- 带参数通用查询结果列 -->
    <sql id="Base_Column_With_Param_List">
        <![CDATA[
            ${tAlias}.demand_id as ${tAlias}_demand_id, ${tAlias}.re_content as ${tAlias}_re_content,
            ${tAlias}.id as ${tAlias}_id, ${tAlias}.create_time as ${tAlias}_create_time,
            ${tAlias}.update_by as ${tAlias}_update_by, ${tAlias}.update_time as ${tAlias}_update_time,
            ${tAlias}.create_by as ${tAlias}_create_by, ${tAlias}.enabled_flag as ${tAlias}_enabled_flag,
             ${tAlias}.edit_by as ${tAlias}_edit_by
        ]]>
    </sql>

    <sql id="Base_Column_Query_Sql">
        <![CDATA[
            select
        ]]>
        <include refid="Base_Column_List"/>
        <![CDATA[
              from re_demand_tracking rdt
        ]]>
    </sql>

    <sql id="Select_All_Criteria_Sql">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
        <if test="criteria != null">
            <if test="criteria.enabledFlag != null">
                <![CDATA[
                    and rdt.enabled_flag = #{criteria.enabledFlag,jdbcType=BIT}
                ]]>
            </if>
            <if test="criteria.demandId != null">
                <![CDATA[
                    and rdt.demand_id = #{criteria.demandId,jdbcType=BIGINT}
                ]]>
            </if>
        </if>
    </sql>

    <insert id="insertAllColumn" parameterType="com.sunten.hrms.re.domain.ReDemandTracking" useGeneratedKeys="true" keyProperty="id">
        <![CDATA[
            insert into re_demand_tracking (demand_id, re_content,
                                            create_time, update_by,
                                            update_time, create_by, enabled_flag, edit_by)
            values (#{demandId,jdbcType=BIGINT}, #{reContent,jdbcType=VARCHAR},
                    #{createTime,jdbcType=TIMESTAMP}, #{updateBy,jdbcType=BIGINT},
                    #{updateTime,jdbcType=TIMESTAMP}, #{createBy,jdbcType=BIGINT},
                    #{enabledFlag, jdbcType = BIT}, #{editBy, jdbcType = VARCHAR})
        ]]>
    </insert>

    <sql id="Delete_Sql">
        <![CDATA[
            delete
              from re_demand_tracking
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </sql>

    <delete id="deleteByKey">
        <include refid="Delete_Sql"/>
    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.re.domain.ReDemandTracking">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="deleteByEnabled">
                <![CDATA[
            update re_demand_tracking set enabled_flag = 0,
            update_time = getdate(),
            update_by = #{userId, jdbcType = BIGINT}
             where id = #{id,jdbcType=BIGINT}

        ]]>
    </update>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.re.domain.ReDemandTracking">
        <![CDATA[
            update re_demand_tracking
               set demand_id   = #{demandId,jdbcType=BIGINT},
                   re_content  = #{reContent,jdbcType=VARCHAR},
                   update_by   = #{updateBy,jdbcType=BIGINT},
                   update_time = #{updateTime,jdbcType=TIMESTAMP},
                   enabled_flag = #{enabledFlag, jdbcType = BIT},
                   edit_by = #{editBy, jdbcType = VARCHAR}
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="ReDemandTrackingResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where rdt.id = #{id,jdbcType=BIGINT}
        ]]>
    </select>

    <select id="listAllByCriteria" resultMap="ReDemandTrackingResultMap">
        <include refid="Select_All_Criteria_Sql"/>
        <![CDATA[
            order by id
        ]]>
    </select>

    <select id="listAllByCriteriaPage" resultMap="ReDemandTrackingResultMap">
        <include refid="Select_All_Criteria_Sql"/>
    </select>

</mapper>
