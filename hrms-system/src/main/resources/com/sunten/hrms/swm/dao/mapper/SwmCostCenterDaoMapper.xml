    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        <![CDATA[
            scc.id, scc.order_num, scc.cost_center_num, scc.cost_center_name, scc.create_time, scc.create_by, 
            scc.update_time, scc.update_by 
        ]]>
    </sql>

    <!-- 带参数通用查询结果列 -->
    <sql id="Base_Column_With_Param_List">
        <![CDATA[
            ${tAlias}.id as ${tAlias}_id, ${tAlias}.order_num as ${tAlias}_order_num, 
            ${tAlias}.cost_center_num as ${tAlias}_cost_center_num, 
            ${tAlias}.cost_center_name as ${tAlias}_cost_center_name, 
            ${tAlias}.create_time as ${tAlias}_create_time, ${tAlias}.create_by as ${tAlias}_create_by, 
            ${tAlias}.update_time as ${tAlias}_update_time, ${tAlias}.update_by as ${tAlias}_update_by 
        ]]>
    </sql>

    <sql id="Base_Column_Query_Sql">
        <![CDATA[
            select
        ]]>
        <include refid="Base_Column_List"/>
        <![CDATA[
              from swm_cost_center scc
        ]]>
    </sql>

    <sql id="Select_All_Criteria_Sql">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where 1 = 1
        ]]>
<!--        <if test="criteria != null">-->
<!--        <if test="criteria.xxxx != null">-->
<!--            <![CDATA[-->
<!--                and scc.xxxxx like #{criteria.xxxx,jdbcType=xxxx}-->
<!--            ]]>-->
<!--        </if>-->
<!--        </if>-->
    </sql>

    <insert id="insertAllColumn" parameterType="com.sunten.hrms.swm.domain.SwmCostCenter" useGeneratedKeys="true" keyProperty="id">
        <![CDATA[
            insert into swm_cost_center (order_num, cost_center_num,
                                         cost_center_name, create_time,
                                         create_by, update_time, update_by)
            values (#{orderNum,jdbcType=BIGINT}, #{costCenterNum,jdbcType=VARCHAR},
                    #{costCenterName,jdbcType=VARCHAR}, #{createTime,jdbcType=TIMESTAMP},
                    #{createBy,jdbcType=BIGINT}, #{updateTime,jdbcType=TIMESTAMP}, #{updateBy,jdbcType=BIGINT})
        ]]>
    </insert>

    <sql id="Delete_Sql">
        <![CDATA[
            delete
              from swm_cost_center
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </sql>

    <delete id="deleteByKey">
        <include refid="Delete_Sql"/>
    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.swm.domain.SwmCostCenter">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.swm.domain.SwmCostCenter">
        <![CDATA[
            update swm_cost_center
               set order_num        = #{orderNum,jdbcType=BIGINT},
                   cost_center_num  = #{costCenterNum,jdbcType=VARCHAR},
                   cost_center_name = #{costCenterName,jdbcType=VARCHAR},
                   update_time      = #{updateTime,jdbcType=TIMESTAMP},
                   update_by        = #{updateBy,jdbcType=BIGINT}
             where id = #{id,jdbcType=BIGINT}
        ]]>
    </update>

    <select id="getByKey" resultMap="SwmCostCenterResultMap">
        <include refid="Base_Column_Query_Sql"/>
        <![CDATA[
             where scc.id = #{id,jdbcType=BIGINT}
        ]]>
