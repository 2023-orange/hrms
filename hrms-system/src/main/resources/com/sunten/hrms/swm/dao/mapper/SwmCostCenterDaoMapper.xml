    <select id="listAllByCriteria" resultMap="SwmCostCenterResultMap">
        <include refid="Select_All_Criteria_Sql"/>
        <![CDATA[
            order by id
        ]]>
    </select>

    <select id="listAllByCriteriaPage" resultMap="SwmCostCenterResultMap">
        <include refid="Select_All_Criteria_Sql"/>
    </select>

</mapper>
