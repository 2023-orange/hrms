    <insert id="insertAllColumn" parameterType="com.sunten.hrms.swm.domain.SwmNolimitationDept">
        <![CDATA[
            insert into swm_noLimitation_dept (dept_name, enabled_flag,
                                               create_time, create_by,
                                               update_time, update_by)
            values (#{deptName,jdbcType=VARCHAR}, 1,
                    #{createTime,jdbcType=TIMESTAMP}, #{createBy,jdbcType=BIGINT},
                    #{updateTime,jdbcType=TIMESTAMP}, #{updateBy,jdbcType=BIGINT})
        ]]>
    </insert>

    <sql id="Delete_Sql">
