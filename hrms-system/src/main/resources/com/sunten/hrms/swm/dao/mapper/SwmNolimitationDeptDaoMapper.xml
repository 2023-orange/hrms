        select count(*) from swm_noLimitation_dept where dept_name = #{deptName,jdbcType=VARCHAR} and enabled_flag = 1

    </select>

    <select id="getSwmDept" resultMap="SwmDeptMap">

        select distinct(department) from swm_employee

