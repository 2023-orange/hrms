    </delete>

    <delete id="deleteByEntityKey" parameterType="com.sunten.hrms.swm.domain.SwmNolimitationDept">
        <include refid="Delete_Sql"/>
    </delete>

    <update id="updateAllColumnByKey" parameterType="com.sunten.hrms.swm.domain.SwmNolimitationDept">
        <![CDATA[
            update swm_noLimitation_dept
               set dept_name     = #{deptName,jdbcType=VARCHAR},
                   enabled_flag = #{enabledFlag,jdbcType=BIGINT},
                   update_time = #{updateTime,jdbcType=TIMESTAMP},
                   update_by   = #{updateBy,jdbcType=BIGINT}
               where id = #{id,jdbcType=BIGINT}
        ]]>
